{
  "name": "test-express-api-starter",
  "version": "1.0.0",
  "description": "First api project",
  "license": "ISC",
  "author": "FOFANA12",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest --runInBand",
    "prisma:seed": "prisma db seed"
  },
  "dependencies": {
    "@prisma/adapter-mariadb": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "http-status-codes": "^2.3.0",
    "morgan": "^1.10.1"
  },
  "devDependencies": {
    "@babel/preset-typescript": "^7.29.7",
    "@jest/globals": "^30.4.1",
    "dotenv-cli": "^11.0.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.14",
    "prisma": "^7.8.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "testMatch": [
      "**/tests/**/*.test.js"
    ],
    "setupFiles": [
      "<rootDir>/tests/setup.js"
    ]
  }
}
